# SPDX-License-Identifier: Apache-2.0
# Copyright 2026 Bharath Kumar Gajjela
#
# versions.env — SINGLE source of truth for the GPU software chain.
#
# The driver, CUDA toolkit, and PyTorch wheel index are a LOCKED chain: if any
# one drifts out of step, the GPU silently falls back to CPU or fails to load.
# To upgrade CUDA in the future, edit the four values below and rebuild — nothing
# else in the GPU scripts hard-codes a version.
#
# Compatibility rule (do not break this):
#   NVIDIA_DRIVER_BRANCH must support CUDA_SERIES, and TORCH_CUDA_INDEX must
#   match CUDA_SERIES. Current pinning:
#     driver 570 -> CUDA 12.8 -> torch cu128
#   References:
#     https://docs.nvidia.com/deploy/cuda-compatibility/
#     https://pytorch.org/get-started/locally/   (wheel index per CUDA series)
#
# Sourced by: scripts/install-cuda.sh, scripts/build-gpu-envs.sh
#
# shellcheck disable=SC2034  # values are consumed by sourcing scripts

# NVIDIA driver branch. apt package: cuda-drivers-${NVIDIA_DRIVER_BRANCH}
# To pin an exact patch instead of the branch metapackage (maximum
# reproducibility), set NVIDIA_DRIVER_PKG below to e.g. "cuda-drivers-570=570.86.15-1".
NVIDIA_DRIVER_BRANCH="570"
NVIDIA_DRIVER_PKG="cuda-drivers-${NVIDIA_DRIVER_BRANCH}"

# CUDA toolkit series in apt package form (note the hyphen, not a dot).
# apt package: cuda-toolkit-${CUDA_SERIES}  e.g. cuda-toolkit-12-8
CUDA_SERIES="12-8"
CUDA_TOOLKIT_PKG="cuda-toolkit-${CUDA_SERIES}"

# Human-readable CUDA version, used for the /usr/local/cuda-<X.Y> symlink check.
CUDA_DOTTED="12.8"

# PyTorch CUDA wheel index. Must correspond to CUDA_SERIES.
# aarch64 CUDA wheels for torch are ONLY published on this index (PyTorch 2.8+);
# PyPI default is CPU-only on aarch64. x86_64 also uses this index.
TORCH_CUDA_INDEX="cu128"
TORCH_CHANNEL="https://download.pytorch.org/whl/${TORCH_CUDA_INDEX}"

# Ubuntu distro tag for the NVIDIA apt repository.
NVIDIA_REPO_DISTRO="ubuntu2204"
